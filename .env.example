# GitHub Personal Access Token (repo + workflow permissions)
# Create at: https://github.com/settings/tokens/new
GITHUB_TOKEN=

# Vercel credentials
# Token: https://vercel.com/account/tokens
# Team ID is shown on your Vercel dashboard URL or team settings
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Supabase project credentials
# Find these in your project dashboard: https://supabase.com/dashboard/projects
SUPABASE_URL=

# Supabase anon key: used by the frontend/browser client (safe with RLS)
# Project Settings → API → anon public
SUPABASE_ANON_KEY=

# Supabase service_role key: used server-side to bypass RLS for admin/migration tasks
# Project Settings → API → service_role key (keep secret, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API token: required to execute database.sql automatically
# Get it at: https://supabase.com/dashboard/account/tokens
SUPABASE_MANAGEMENT_TOKEN=
